rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidNote(data) {
      return data.keys().hasAll(['title', 'content', 'userId', 'pinned', 'createdAt', 'updatedAt'])
        && data.keys().size() == 6
        && data.title is string
        && data.title.size() <= 500
        && data.content is string
        && data.content.size() <= 100000
        && data.userId is string
        && data.userId == request.auth.uid
        && data.pinned is bool
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    match /notes/{noteId} {
      allow get: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && isValidId(noteId)
        && isValidNote(request.resource.data)
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
      allow update: if isSignedIn()
        && isValidId(noteId)
        && isValidNote(request.resource.data)
        && isOwner(existing().userId)
        && request.resource.data.userId == existing().userId
        && request.resource.data.createdAt == existing().createdAt
        && request.resource.data.updatedAt == request.time
        && request.resource.data.diff(existing()).affectedKeys().hasOnly(['title', 'content', 'pinned', 'updatedAt']);
      allow delete: if isSignedIn()
        && isValidId(noteId)
        && isOwner(existing().userId);
    }
  }
}
